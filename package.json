{
  "name": "blog-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "typecheck": "vue-tsc -b",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"src/**/*.{css,scss,vue}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss,vue}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:circular": "madge --extensions ts,vue --ts-config tsconfig.app.json --circular src",
    "check:deps": "knip",
    "check:spell": "cspell .",
    "ci": "pnpm format:check && pnpm lint && pnpm stylelint && pnpm typecheck && pnpm test:coverage && pnpm check:circular && pnpm build",
    "ci:full": "pnpm run ci && pnpm check:deps && pnpm check:spell && pnpm test:e2e",
    "commit": "cz"
  },
  "dependencies": {
    "@sentry/vue": "^10.58.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.0",
    "element-plus": "^2.14.2",
    "pinia": "^3.0.4",
    "three": "^0.184.0",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@iconify-json/ep": "^1.2.4",
    "@playwright/test": "^1.61.0",
    "@sentry/cli": "^3.5.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.12.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "^4.3.2",
    "cspell": "^10.0.1",
    "cz-git": "^1.13.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.4",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "lint-staged": "^17.0.7",
    "madge": "^8.0.0",
    "msw": "^2.14.6",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.12",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=10.8.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{css,scss,vue}": [
      "stylelint --fix"
    ],
    "*.{json,md,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
